<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cursos del Circulo Infernal</title>
</head>
<body>
    <main class="container-main">
        <table class="table" border="1">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Descripción</th>
                    <th>Docente</th>
                </tr>
            </thead>
            <% 
                if(Array.isArray(cursos) && cursos.length > 0){
            %>
            <tbody>
                <tr>
                    <% 
                        cursos.forEach(function(curso){
                    %>
                    <td><%= curso.id%></td>
                    <td><%= curso.nombre || '' %></td>
                    <td><%= curso.descripción || '' %></td>
                    <td><%= curso.docente% || '' %></td>
                </tr>
                <% }); %>
            </tbody>
        </table>
        <% } else { %>
            <div>No hay cursos disponibles en este momento, existe un error al cargarlos.</div>
            <p><a href="../views/bienivenida.html">Volver a Bienvenida</a></p>
        <% };%>
    </main>
</body>
</html>